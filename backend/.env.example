DATABASE_URL=postgresql://user:password@localhost:5432/prodeazo
REDIS_URL=redis://localhost:6379
# Use memory for sessions when Redis is not running (fixtures cache still tries Redis; errors are throttled).
# SESSION_STORE=memory
SESSION_SECRET=change_this_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/callback
FRONTEND_URL=http://localhost:5173
# Secret key only (no "Token " prefix). If you paste "Token abc...", the app strips the prefix.
BZZOIRO_API_KEY=your_api_token_from_https://sports.bzzoiro.com/register/
BZZOIRO_BASE_URL=https://sports.bzzoiro.com/api
# Provider + proxy routes use BSD API v2 paths (/v2/events/, /v2/teams/, …) under this base.
# Optional. Default Token (per BSD docs). Try Bearer only if your dashboard specifies it.
# BZZOIRO_AUTH_SCHEME=Token
# Seed fixtures — priority: (1) date range below (2) BZZOIRO_FIXTURE_SEASON_IDS (3) BZZOIRO_LEAGUE_ID alone (4) TOURNAMENT_ID.
# Multiple BSD seasons for same tournament (e.g. WC grupo + knockout): overrides single TOURNAMENT_ID for fixtures only.
# Example Mundial 2026: BZZOIRO_FIXTURE_SEASON_IDS=383,188
# BZZOIRO_FIXTURE_SEASON_IDS=
# Single season fallback when no league / no FIXTURE_SEASON_IDS (solo una fase BSD).
TOURNAMENT_ID=
# BSD league id — recommended: GET /api/v2/events/?league_id=… trae todas las temporadas (grupos + eliminatorias + ediciones viejas).
# Para solo la edición actual sin Mundiales pasados, usá FIXTURE_SEASON_IDS o un rango de fechas.
BZZOIRO_LEAGUE_ID=
# Optional limit hint for v2 teams list (capped at 200/page; pagination follows `next`).
# BZZOIRO_V2_TEAMS_LIMIT=1000
# Opcional: más páginas al paginar /v2/events/ (default 100 → hasta ~20k eventos).
# BZZOIRO_EVENTS_MAX_PAGES=120
# Seed por rango: league id + fechas inclusivas YYYY-MM-DD.
# BZZOIRO_EVENTS_DATE_FROM=2026-06-11
# BZZOIRO_EVENTS_DATE_TO=2026-07-19
BSD_TIMEZONE=UTC
# Seconds to cache GET /api/teams/:id/players (Bzzoiro proxy). Default 120.
# BZZOIRO_PLAYERS_CACHE_TTL_SEC=120
NODE_ENV=development
PORT=3000
# HTTP access log (morgan): dev | combined | common | short | tiny — see https://github.com/expressjs/morgan
# MORGAN_FORMAT=combined
